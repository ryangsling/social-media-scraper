# ─── App ─────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Apify (Paid — starts $49/mo) ────────────────────
# Get token at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ─── Twitter/X API (Optional paid) ───────────────────
# Get at: https://developer.twitter.com  (Basic = $100/mo)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# ─── Reddit API (Free!) ───────────────────────────────
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SocialScraper/1.0

# ─── Instagram (Optional, for login-gated content) ───
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ─── Runtime / Ops ───────────────────────────────────
# Comma-separated, no spaces. Use "*" only for local testing without cookies.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Timeout for each scraper call inside worker task
SCRAPER_TIMEOUT_SECONDS=90

# ─── Infra (usually set by docker-compose) ───────────
DATABASE_URL=postgresql://scraper:scraper123@db:5432/scraper_db
REDIS_URL=redis://redis:6379/0
